# Slice 2a integration-test environment.
#
# Copy to `.env.test` (git-ignored) and fill in. WITHOUT this file the suite
# auto-skips — it will never run against a project you didn't explicitly point
# it at. NEVER point this at production (project ryxklkayezjnwwunuphn).
#
# Recommended: a local `supabase start` stack. `supabase start` prints these
# values (API URL + anon key + service_role key).

# --- Target project (local stack shown) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<local anon key from `supabase start`>

# Service role is used ONLY by the fixture seeder (create auth users, insert
# the disposable event/roster/schedule, and tear it all down). Never shipped
# to the client. Omit to disable auto-seeding and supply TEST_EVENT_ID instead.
SUPABASE_SERVICE_ROLE_KEY=<local service_role key from `supabase start`>

# --- Organizer identity the RPC runs as (must own the seeded event) ---
# The seeder creates this user if it doesn't exist (needs service role).
TEST_ORGANIZER_EMAIL=rr-organizer@example.test
TEST_ORGANIZER_PASSWORD=rr-organizer-pw-change-me

# --- Optional: reuse a pre-seeded event instead of auto-seeding ---
# If set, the suite uses this event and its participants verbatim and performs
# NO seeding/teardown. Leave unset to let the seeder build a fresh event.
# TEST_EVENT_ID=
# TEST_PARTICIPANT_IDS=<comma-separated round_robin_players.id values>
