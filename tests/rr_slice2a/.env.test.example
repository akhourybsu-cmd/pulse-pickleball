# Slice 2a integration-test environment.
#
# Copy to `.env.test` (git-ignored) and fill in. WITHOUT this file the suite
# auto-skips. The allowlist guard (guard.ts) refuses to run unless every
# endpoint below agrees on RR_TEST_PROJECT_REF and it is NOT production
# (ryxklkayezjnwwunuphn / supabase/config.toml project_id).

# --- REQUIRED allowlist: the exact disposable project ref you intend to hit ---
# For a cloud project this is the ref from https://<ref>.supabase.co.
# For a local `supabase start` stack, set it to the literal string: local
RR_TEST_PROJECT_REF=<disposable-project-ref>

# --- Target project ---
# Cloud:  https://<disposable-project-ref>.supabase.co
# Local:  http://127.0.0.1:54321   (http allowed only for 127.0.0.1/localhost)
SUPABASE_URL=https://<disposable-project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon key>

# --- Exactly ONE administrative key (never commit / never expose to browser) ---
# Legacy service-role JWT:
SUPABASE_SERVICE_ROLE_KEY=<service_role key>
# OR the newer secret key format (set only one, not both):
# SUPABASE_SECRET_KEY=sb_secret_...

# --- Organizer identity the RPC runs as (seeder creates this user) ---
TEST_ORGANIZER_EMAIL=rr-organizer@example.test
TEST_ORGANIZER_PASSWORD=rr-organizer-pw-change-me

# --- Optional: direct Postgres for the catalog/security spec ---
# Cloud:  postgresql://postgres:<db-password>@db.<disposable-project-ref>.supabase.co:5432/postgres
# Local:  postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Must reference the same project as RR_TEST_PROJECT_REF. Omit → security.spec skips.
# DATABASE_URL=

# --- Optional: reuse a pre-seeded event instead of auto-seeding ---
# TEST_EVENT_ID=
# TEST_PARTICIPANT_IDS=<comma-separated round_robin_players.id values>
